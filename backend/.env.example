# =============================================================================
# DDN Infinia RAG Demo — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git — it contains secret API keys.
# =============================================================================

# ── NVIDIA NIM API (required for LLM inference) ───────────────────────────────
# Get a free key at: https://build.nvidia.com
NVIDIA_API_KEY=nvapi-your-key-here

# ── HuggingFace (optional — only for gated/private models) ───────────────────
HUGGINGFACE_TOKEN=hf_your-token-here

# ── Storage credentials are configured via the app UI ────────────────────────
# See backend/data/storage_config.example.json for the format.
